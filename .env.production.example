# Docker Compose 自身配置
WEB_PORT=8080
IMAGE_TAG=latest

# 应用基础配置
APP_NAME=Hotel AI Order Agent
APP_ENV=test
LOG_LEVEL=INFO
DEBUG_TRACE_ENABLED=false

# 主对话模型（必须填写）
OPENAI_API_KEY=replace-with-your-llm-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.5-plus
OPENAI_TEMPERATURE=0.2

# 商品向量检索（必须填写）
QWEN_EMBEDDING_API_KEY=replace-with-your-qwen-embedding-api-key
QWEN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_BATCH_SIZE=10
QWEN_EMBEDDING_TIMEOUT_SECONDS=30
PRODUCT_SEARCH_THRESHOLD=0.55

# 数据和会话
SQLITE_MEMORY_PATH=/app/data/agent_memory.sqlite3
EMBEDDING_CACHE_DIR=/app/data/embedding_cache
SPU_EXCEL_PATH=assets/spu.xlsx
CONVERSATION_SUMMARY_MAX_MESSAGES=12
REDIS_TTL_SECONDS=86400

# PostgreSQL。测试服务器也请替换成随机强密码。
POSTGRES_DB=agent_db
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=replace-with-a-strong-password

# LangSmith（不用可保持关闭）
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hotel-ai-order-agent-test
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 业务接口。容器必须能够访问这些地址。
USER_APP_BASE_URL=http://192.168.2.223:18080
USER_APP_SUBMIT_ENABLED=false
USER_APP_TIMEOUT_SECONDS=30
ADMIN_API_BASE_URL=http://192.168.2.223:18080
LOGIN_PROFILE_URL=http://192.168.2.223:18080/admin-api/system/user/profile/get

# 可选联网搜索
TAVILY_API_KEY=
