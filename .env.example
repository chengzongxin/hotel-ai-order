APP_NAME=LangGraph FastAPI Agent
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DEBUG_TRACE_ENABLED=false

OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hotel-ai-order-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

REDIS_URL=redis://redis:6379/0
REDIS_TTL_SECONDS=86400

SQLITE_MEMORY_PATH=data/agent_memory.sqlite3
CONVERSATION_SUMMARY_MAX_MESSAGES=12

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agent_db
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_password
POSTGRES_ENABLED=false

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agent_knowledge

SPU_EXCEL_PATH=assets/spu.xlsx
EMBEDDING_CACHE_DIR=data/embedding_cache
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_EMBEDDING_API_KEY=
QWEN_EMBEDDING_BATCH_SIZE=10
QWEN_EMBEDDING_TIMEOUT_SECONDS=30
PRODUCT_SEARCH_THRESHOLD=0.55

USER_APP_BASE_URL=http://192.168.2.223:18080
USER_APP_SUBMIT_ENABLED=false
USER_APP_TIMEOUT_SECONDS=30

# 集成测试用（pytest tests/test_chat_flow.py），从真实登录用户获取
TEST_ACCESS_TOKEN=
TEST_USER_ID=
TEST_TENANT_ID=
TEST_PLATFORM=ios
TEST_APP_TYPE=2
TEST_DEVICE_ID=
TEST_APP_VERSION=
TEST_APP_CHANNEL=
TEST_APP_SPIRIT=

ADMIN_API_BASE_URL=http://192.168.2.223:18080
